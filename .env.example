# ============================================================================
# PulseOps V2 — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# Server
PORT=4001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulseops_v2
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SCHEMA=pulseops
DB_POOL_SIZE=10

# Auth
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_ROUNDS=12

# CDN (optional, for production module serving)
CDN_BASE_URL=/api/modules/bundle
