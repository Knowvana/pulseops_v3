{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@src/*":     ["src/*"],
      "@config/*":  ["src/client/config/*"],
      "@core/*":    ["src/client/core/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*":  ["src/client/shared/*"],
      "@shared":    ["src/client/shared/index.js"],
      "@layouts/*": ["src/client/layouts/*"],
      "@layouts":   ["src/client/layouts/index.js"],
      "@components/*": ["src/ReusableComponents/*"],
      "@components":   ["src/ReusableComponents/index.js"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-modules"]
}
