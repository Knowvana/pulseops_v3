{
  "_meta": {
    "moduleId": "servicenow",
    "version": "2.0.0",
    "description": "ServiceNow ITSM Integration — module database schema. Tables are provisioned when the module is enabled via Module Manager. Uses the same JSON format as DefaultDatabaseSchema.json. Architecture: sn_module_config for key-value JSONB config, sn_sla_config for structured SLA CRUD, sn_business_hours for 7-row weekly schedule, sn_sync_history for audit, sn_auto_acknowledge_log for auto-ack audit. Incidents are fetched live from the ServiceNow API."
  },
  "tables": [
    {
      "name": "sn_module_config",
      "description": "Consolidated module configuration — key-value store with JSONB values. Replaces sn_incident_config and JSON config files. Keys: incident_config, connection, sync_settings, general_settings.",
      "columns": [
        { "name": "id",          "type": "SERIAL PRIMARY KEY" },
        { "name": "config_key",  "type": "VARCHAR(100) UNIQUE NOT NULL" },
        { "name": "config_value","type": "JSONB NOT NULL DEFAULT '{}'::jsonb" },
        { "name": "description", "type": "TEXT" },
        { "name": "created_at",  "type": "TIMESTAMPTZ DEFAULT NOW()" },
        { "name": "updated_at",  "type": "TIMESTAMPTZ DEFAULT NOW()" }
      ],
      "indexes": [
        { "name": "idx_sn_module_config_key", "columns": ["config_key"], "unique": true }
      ]
    },
    {
      "name": "sn_sla_config",
      "description": "SLA configuration per priority level — response and resolution times in minutes. Structured CRUD table with industry-standard defaults for P1-P4.",
      "columns": [
        { "name": "id",                  "type": "SERIAL PRIMARY KEY" },
        { "name": "priority",            "type": "VARCHAR(50) UNIQUE NOT NULL" },
        { "name": "priority_value",      "type": "VARCHAR(10) NOT NULL DEFAULT '4'" },
        { "name": "response_minutes",    "type": "INTEGER NOT NULL DEFAULT 60" },
        { "name": "resolution_minutes",  "type": "INTEGER NOT NULL DEFAULT 480" },
        { "name": "enabled",             "type": "BOOLEAN DEFAULT TRUE" },
        { "name": "sort_order",          "type": "INTEGER NOT NULL DEFAULT 99" },
        { "name": "created_at",          "type": "TIMESTAMPTZ DEFAULT NOW()" },
        { "name": "updated_at",          "type": "TIMESTAMPTZ DEFAULT NOW()" }
      ],
      "indexes": [
        { "name": "idx_sn_sla_config_priority", "columns": ["priority"], "unique": true },
        { "name": "idx_sn_sla_config_priority_value", "columns": ["priority_value"], "unique": false }
      ]
    },
    {
      "name": "sn_business_hours",
      "description": "Weekly business hours schedule — exactly 7 rows (Sun-Sat). Used for SLA calculations. Rows cannot be deleted, only updated (start_time, end_time, is_business_day).",
      "columns": [
        { "name": "id",              "type": "SERIAL PRIMARY KEY" },
        { "name": "day_of_week",     "type": "INTEGER UNIQUE NOT NULL" },
        { "name": "day_name",        "type": "VARCHAR(20) NOT NULL" },
        { "name": "is_business_day", "type": "BOOLEAN NOT NULL DEFAULT FALSE" },
        { "name": "start_time",      "type": "TIME NOT NULL DEFAULT '09:00'" },
        { "name": "end_time",        "type": "TIME NOT NULL DEFAULT '17:00'" },
        { "name": "created_at",      "type": "TIMESTAMPTZ DEFAULT NOW()" },
        { "name": "updated_at",      "type": "TIMESTAMPTZ DEFAULT NOW()" }
      ],
      "indexes": [
        { "name": "idx_sn_business_hours_dow", "columns": ["day_of_week"], "unique": true }
      ]
    },
    {
      "name": "sn_sync_history",
      "description": "Sync audit trail — records each ServiceNow sync operation.",
      "columns": [
        { "name": "id",               "type": "BIGSERIAL PRIMARY KEY" },
        { "name": "sync_type",        "type": "VARCHAR(50) NOT NULL DEFAULT 'incidents'" },
        { "name": "status",           "type": "VARCHAR(20) NOT NULL DEFAULT 'running'" },
        { "name": "records_fetched",  "type": "INTEGER DEFAULT 0" },
        { "name": "records_created",  "type": "INTEGER DEFAULT 0" },
        { "name": "records_updated",  "type": "INTEGER DEFAULT 0" },
        { "name": "error_message",    "type": "TEXT" },
        { "name": "started_at",       "type": "TIMESTAMPTZ DEFAULT NOW()" },
        { "name": "completed_at",     "type": "TIMESTAMPTZ" },
        { "name": "duration_ms",      "type": "INTEGER" }
      ],
      "indexes": [
        { "name": "idx_sn_sync_history_status",     "columns": ["status"],     "unique": false },
        { "name": "idx_sn_sync_history_started_at", "columns": ["started_at"], "unique": false }
      ]
    },
    {
      "name": "sn_auto_acknowledge_log",
      "description": "Auto acknowledge audit trail — records each incident that was auto-acknowledged with the configured message.",
      "columns": [
        { "name": "id",                 "type": "BIGSERIAL PRIMARY KEY" },
        { "name": "incident_number",    "type": "VARCHAR(40) NOT NULL" },
        { "name": "incident_sys_id",    "type": "VARCHAR(64) NOT NULL" },
        { "name": "short_description",  "type": "TEXT" },
        { "name": "priority",           "type": "VARCHAR(50)" },
        { "name": "state",              "type": "VARCHAR(20)" },
        { "name": "acknowledge_message","type": "TEXT NOT NULL" },
        { "name": "status",             "type": "VARCHAR(20) NOT NULL DEFAULT 'success'" },
        { "name": "error_message",      "type": "TEXT" },
        { "name": "acknowledged_at",    "type": "TIMESTAMPTZ DEFAULT NOW()" }
      ],
      "indexes": [
        { "name": "idx_sn_auto_ack_log_number",     "columns": ["incident_number"], "unique": false },
        { "name": "idx_sn_auto_ack_log_sys_id",     "columns": ["incident_sys_id"], "unique": false },
        { "name": "idx_sn_auto_ack_log_acked_at",   "columns": ["acknowledged_at"], "unique": false },
        { "name": "idx_sn_auto_ack_log_status",     "columns": ["status"],          "unique": false }
      ]
    }
  ]
}
