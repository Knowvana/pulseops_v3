{
  "name": "pulseops-v3",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "description": "PulseOps V3 — Enterprise Operations Platform (Unified Monorepo)",
  "scripts": {
    "dev": "concurrently -n UI,API -c cyan,green \"npm run dev:ui\" \"npm run dev:api\"",
    "dev:ui": "vite",
    "dev:api": "node src/apiserver/server.js",
    "dev:api:watch": "node --watch-path=src/apiserver --watch-path=src/modules --watch-preserve-output src/apiserver/server.js",
    "build": "vite build",
    "build:module": "node scripts/build-module.js",
    "preview": "vite preview",
    "start:api": "node src/apiserver/server.js"
  },
  "imports": {
    "#config/*": "./src/apiserver/config/*",
    "#config": "./src/apiserver/config/index.js",
    "#shared/*": "./src/apiserver/shared/*",
    "#core/*": "./src/apiserver/core/*",
    "#root/*": "./src/apiserver/*",
    "#modules/*": "./src/modules/*",
    "#apiRoot/*": "./*"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "pg": "^8.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  }
}
