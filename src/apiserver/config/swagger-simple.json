{
  "openapi": "3.0.3",
  "info": {
    "title": "PulseOps V2 API",
    "version": "2.0.0",
    "description": "Simple API documentation"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base path"
    }
  ],
  "paths": {
    "/auth/superadmin/login": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "superadminLogin",
        "summary": "SuperAdmin login",
        "description": "Authenticates SuperAdmin and returns JWT token.",
        "responses": {
          "200": { "description": "Login successful." },
          "400": { "description": "Missing email or password." },
          "401": { "description": "Invalid email or password." }
        }
      }
    },
    "/accessio_ops/cluster": {
      "get": {
        "tags": ["Accessio Operations - Cluster"],
        "operationId": "aoGetClusterConfig",
        "summary": "Get cluster configuration",
        "description": "Returns the current Kubernetes cluster configuration.",
        "responses": {
          "200": { "description": "Cluster configuration loaded successfully." },
          "401": { "description": "Authentication required." },
          "500": { "description": "Failed to load configuration." }
        }
      },
      "put": {
        "tags": ["Accessio Operations - Cluster"],
        "operationId": "aoUpdateClusterConfig",
        "summary": "Update cluster configuration",
        "description": "Saves the Kubernetes cluster configuration.",
        "responses": {
          "200": { "description": "Configuration saved successfully." },
          "400": { "description": "Missing required fields." },
          "401": { "description": "Authentication required." },
          "500": { "description": "Failed to save configuration." }
        }
      }
    },
    "/accessio_ops/config": {
      "get": {
        "tags": ["Accessio Operations - Config"],
        "operationId": "aoGetModuleConfig",
        "summary": "Get module configuration",
        "description": "Returns the module configuration from clusterconfig.json file.",
        "responses": {
          "200": { "description": "Module configuration retrieved successfully." },
          "404": { "description": "Configuration file not found." },
          "422": { "description": "Invalid JSON in configuration file." },
          "500": { "description": "Failed to read configuration file." }
        }
      }
    },
    "/accessio_ops/cluster/test": {
      "post": {
        "tags": ["Accessio Operations - Cluster"],
        "operationId": "aoTestClusterConnection",
        "summary": "Test cluster connection",
        "description": "Tests connectivity to the Kubernetes cluster.",
        "responses": {
          "200": { "description": "Connection test successful." },
          "400": { "description": "Missing required fields." },
          "401": { "description": "Authentication required." },
          "500": { "description": "Connection test failed." }
        }
      }
    }
  }
}
